{
  "main": {
    "wallpaper_dir": "~/Pictures/Wallpapers",
    "thumbnail_size": 256,
    "thumbnail_shape": "landscape",
    "batch_size": 16,
    "window_decorations": false,
    "window_grid_cols": 3,
    "window_grid_rows": 3,
    "window_grid_max_width_pct": 80,
    "mouse_enabled": true,
    "keep_ui_alive": false
    },
    "wall": {
        "wall_mode_only": true,
        "wall_awww_flags": "--transition-type random --transition-duration 2 --transition-fps 60"
    },
    "panel": {
        "panel_mode": false,
        "panel_edge": "left",
        "panel_thumbs_col": 4,
        "panel_exclusive_zone": -1,
        "panel_margin_top": 45,
        "panel_margin_bottom": 0,
        "panel_margin_left": 0,
        "panel_margin_right": 0
    }
}